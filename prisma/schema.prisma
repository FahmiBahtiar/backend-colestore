generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  password          String
  name              String?
  role              Role               @default(BUYER)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  activityLogs      ActivityLog[]      @relation("ActorLogs")
  coupons           Coupon[]           @relation("UserCoupons")
  deliveredOrders   Order[]            @relation("DeliveredBy")
  orders            Order[]
  pointTransactions PointTransaction[]
  createdProducts   Product[]          @relation("CreatedByAdmin")

  @@map("users")
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  imageKey String?
  products Product[]

  @@map("categories")
}

model Product {
  id             String                 @id @default(cuid())
  name           String
  slug           String                 @unique
  description    String?
  basePrice      Decimal
  isActive       Boolean                @default(true)
  hasVariants    Boolean                @default(false)
  stockQuantity  Int?
  digitalFileKey String?
  imageKey       String?
  categoryId     String?
  createdById    String
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  orderItems     OrderItem[]
  checkoutFields ProductCheckoutField[]
  variants       ProductVariant[]
  category       Category?              @relation(fields: [categoryId], references: [id])
  createdBy      User                   @relation("CreatedByAdmin", fields: [createdById], references: [id])

  @@map("products")
}

model ProductVariant {
  id            String      @id @default(cuid())
  name          String
  price         Decimal?
  stockQuantity Int?
  productId     String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orderItems    OrderItem[]
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_variants")
}

model Coupon {
  id                String             @id @default(cuid())
  code              String             @unique
  discountType      DiscountType
  discountValue     Decimal
  minOrderAmount    Decimal            @default(0)
  maxUses           Int?
  usedCount         Int                @default(0)
  expiresAt         DateTime?
  isActive          Boolean            @default(true)
  userId            String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User?              @relation("UserCoupons", fields: [userId], references: [id])
  orderItems        OrderItem[]
  appliedOrders     Order[]
  pointTransactions PointTransaction[]

  @@map("coupons")
}

model Order {
  id                       String             @id @default(cuid())
  userId                   String?
  customerEmail            String             @default("")
  customerWhatsapp         String             @default("")
  totalAmount              Decimal
  discountAmount           Decimal            @default(0)
  finalAmount              Decimal
  status                   OrderStatus        @default(PENDING)
  paymentGatewayInvoiceId  String?
  paymentGatewayInvoiceUrl String?
  paymentGatewayExpiresAt  DateTime?
  paymentGatewayRequestId  String?
  paymentMethodType        String?
  paymentChannel           String?
  paymentInstructions      Json?
  paymentProof             String?
  deliveredAt              DateTime?
  deliveredById            String?
  deliveryNote             String?
  couponId                 String?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  activityLogs             ActivityLog[]      @relation("OrderLogs")
  items                    OrderItem[]
  coupon                   Coupon?            @relation(fields: [couponId], references: [id])
  deliveredBy              User?              @relation("DeliveredBy", fields: [deliveredById], references: [id])
  user                     User?              @relation(fields: [userId], references: [id])
  pointTransactions        PointTransaction[]

  @@index([paymentGatewayRequestId])
  @@map("orders")
}

model OrderItem {
  id              String                    @id @default(cuid())
  orderId         String
  productId       String
  variantId       String?
  couponId        String?
  quantity        Int                       @default(1)
  unitPrice       Decimal
  subtotal        Decimal
  checkoutAnswers OrderItemCheckoutAnswer[]
  coupon          Coupon?                   @relation(fields: [couponId], references: [id])
  order           Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product                   @relation(fields: [productId], references: [id])
  variant         ProductVariant?           @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model ProductCheckoutField {
  id         String                    @id @default(cuid())
  productId  String
  label      String
  type       String                    @default("TEXT")
  isRequired Boolean                   @default(true)
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt
  answers    OrderItemCheckoutAnswer[]
  product    Product                   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_checkout_fields")
}

model OrderItemCheckoutAnswer {
  id              String                @id @default(cuid())
  orderItemId     String
  checkoutFieldId String?
  label           String
  value           String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  checkoutField   ProductCheckoutField? @relation(fields: [checkoutFieldId], references: [id])
  orderItem       OrderItem             @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@map("order_item_checkout_answers")
}

model ActivityLog {
  id         String      @id @default(cuid())
  category   LogCategory
  action     String
  entityType String?
  entityId   String?
  actorId    String?
  details    Json?
  createdAt  DateTime    @default(now())
  orderId    String?
  actor      User?       @relation("ActorLogs", fields: [actorId], references: [id])
  order      Order?      @relation("OrderLogs", fields: [orderId], references: [id])

  @@index([category])
  @@index([action])
  @@index([entityType, entityId])
  @@map("activity_logs")
}

model PointTransaction {
  id        String               @id @default(cuid())
  userId    String
  orderId   String?
  couponId  String?
  type      PointTransactionType
  points    Int
  amount    Decimal              @default(0)
  createdAt DateTime             @default(now())
  coupon    Coupon?              @relation(fields: [couponId], references: [id])
  order     Order?               @relation(fields: [orderId], references: [id])
  user      User                 @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([orderId])
  @@map("point_transactions")
}

model PointReward {
  id             String       @id @default(cuid())
  name           String
  description    String?
  pointCost      Int
  discountType   DiscountType
  discountValue  Decimal
  minOrderAmount Decimal      @default(0)
  maxRedemptions Int?
  redeemedCount  Int          @default(0)
  isActive       Boolean      @default(true)
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("point_rewards")
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faqs")
}

model PaymentMethodConfig {
  id                   String   @id @default(cuid())
  type                 String
  channel              String
  name                 String
  isActive             Boolean  @default(true)
  paymentExpiryHours   Int      @default(24)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  paymentExpiryMinutes Int      @default(0)

  @@unique([type, channel])
  @@map("payment_method_configs")
}

model Banner {
  id         String   @id @default(cuid())
  title      String?
  subtitle   String?
  buttonText String?
  buttonLink String?
  imageKey   String
  isActive   Boolean  @default(true)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("banners")
}

enum Role {
  ADMIN
  BUYER
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  DELIVERED
  CANCELLED
  REFUNDED
}

enum LogCategory {
  AUTH
  USER
  PRODUCT
  ORDER
  PAYMENT
  DELIVERY
  COUPON
  SYSTEM
  SECURITY
}

enum PointTransactionType {
  EARNED
  REFUNDED
  REDEEMED
}
