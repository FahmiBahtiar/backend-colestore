generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// USER & AUTHENTICATION
// ============================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(BUYER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders            Order[]
  activityLogs      ActivityLog[]      @relation("ActorLogs")
  createdProducts   Product[]          @relation("CreatedByAdmin")
  deliveredOrders   Order[]            @relation("DeliveredBy")
  pointTransactions PointTransaction[]
  coupons           Coupon[]           @relation("UserCoupons")

  @@map("users")
}

enum Role {
  ADMIN
  BUYER
}

// ============================================================
// PRODUCT & CATEGORY
// ============================================================

model Category {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  products Product[]

  @@map("categories")
}

model Product {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String?
  basePrice      Decimal
  isActive       Boolean  @default(true)
  hasVariants    Boolean  @default(false)
  stockQuantity  Int?
  digitalFileKey String?
  imageKey       String?

  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])

  createdById String
  createdBy   User   @relation("CreatedByAdmin", fields: [createdById], references: [id])

  variants   ProductVariant[]
  orderItems OrderItem[]
  checkoutFields ProductCheckoutField[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}

model ProductVariant {
  id            String   @id @default(cuid())
  name          String
  price         Decimal?
  stockQuantity Int?

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("product_variants")
}

// ============================================================
// COUPON / VOUCHER
// ============================================================

model Coupon {
  id             String       @id @default(cuid())
  code           String       @unique
  discountType   DiscountType
  discountValue  Decimal
  minOrderAmount Decimal      @default(0)
  maxUses        Int?
  usedCount      Int          @default(0)
  expiresAt      DateTime?
  isActive       Boolean      @default(true)

  appliedOrders Order[]
  orderItems    OrderItem[]

  userId         String?
  user           User?        @relation("UserCoupons", fields: [userId], references: [id])

  pointTransactions PointTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("coupons")
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ============================================================
// ORDER & PAYMENT
// ============================================================

model Order {
  id               String      @id @default(cuid())
  userId           String?
  user             User?       @relation(fields: [userId], references: [id])
  customerEmail    String      @default("")
  customerWhatsapp String      @default("")

  totalAmount    Decimal
  discountAmount Decimal     @default(0)
  finalAmount    Decimal

  status           OrderStatus @default(PENDING)
  xenditInvoiceId  String?
  xenditInvoiceUrl String?
  xenditInvoiceExpiresAt DateTime?
  paymentProof     String?

  deliveredAt   DateTime?
  deliveredById String?
  deliveredBy   User?    @relation("DeliveredBy", fields: [deliveredById], references: [id])
  deliveryNote  String?

  couponId String?
  coupon   Coupon? @relation(fields: [couponId], references: [id])

  items             OrderItem[]
  activityLogs      ActivityLog[] @relation("OrderLogs")
  pointTransactions PointTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  DELIVERED
  CANCELLED
  REFUNDED
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  couponId  String?
  coupon    Coupon? @relation(fields: [couponId], references: [id])

  quantity  Int     @default(1)
  unitPrice Decimal
  subtotal  Decimal

  checkoutAnswers OrderItemCheckoutAnswer[]

  @@map("order_items")
}

model ProductCheckoutField {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  label      String
  type       String   @default("TEXT") // TEXT, TEXTAREA
  isRequired Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  answers    OrderItemCheckoutAnswer[]

  @@map("product_checkout_fields")
}

model OrderItemCheckoutAnswer {
  id              String                @id @default(cuid())
  orderItemId     String
  orderItem       OrderItem             @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  checkoutFieldId String?
  checkoutField   ProductCheckoutField? @relation(fields: [checkoutFieldId], references: [id], onDelete: SetNull)
  label           String                // Snapshot of the field label at purchase time
  value           String                // Buyer response/answer value
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@map("order_item_checkout_answers")
}

// ============================================================
// ACTIVITY LOG
// ============================================================

model ActivityLog {
  id         String      @id @default(cuid())
  category   LogCategory
  action     String
  entityType String?
  entityId   String?

  actorId String?
  actor   User?   @relation("ActorLogs", fields: [actorId], references: [id])

  details Json?

  createdAt DateTime @default(now())

  orderId String?
  order   Order?  @relation("OrderLogs", fields: [orderId], references: [id])

  @@index([category])
  @@index([action])
  @@index([entityType, entityId])
  @@map("activity_logs")
}

enum LogCategory {
  AUTH
  USER
  PRODUCT
  ORDER
  PAYMENT
  DELIVERY
  COUPON
  SYSTEM
  SECURITY
}

// ============================================================
// LOYALTY POINTS
// ============================================================

enum PointTransactionType {
  EARNED
  REFUNDED
  REDEEMED
}

model PointTransaction {
  id        String               @id @default(cuid())
  userId    String
  user      User                 @relation(fields: [userId], references: [id])
  orderId   String?
  order     Order?               @relation(fields: [orderId], references: [id])
  couponId  String?
  coupon    Coupon?              @relation(fields: [couponId], references: [id])
  type      PointTransactionType
  points    Int
  amount    Decimal              @default(0)
  createdAt DateTime             @default(now())

  @@index([userId])
  @@index([orderId])
  @@map("point_transactions")
}

model PointReward {
  id             String       @id @default(cuid())
  name           String
  description    String?
  pointCost      Int
  discountType   DiscountType
  discountValue  Decimal
  minOrderAmount Decimal      @default(0)
  maxRedemptions Int?
  redeemedCount  Int          @default(0)
  isActive       Boolean      @default(true)
  expiresAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("point_rewards")
}

// ============================================================
// FAQ
// ============================================================

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faqs")
}

