generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// USER & AUTHENTICATION
// ============================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(BUYER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders          Order[]
  activityLogs    ActivityLog[]    @relation("ActorLogs")
  createdProducts Product[]        @relation("CreatedByAdmin")
  deliveredOrders Order[]          @relation("DeliveredBy")

  @@map("users")
}

enum Role {
  ADMIN
  BUYER
}

// ============================================================
// PRODUCT & CATEGORY
// ============================================================

model Category {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  products Product[]

  @@map("categories")
}

model Product {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String?
  basePrice      Decimal
  isActive       Boolean  @default(true)
  hasVariants    Boolean  @default(false)
  stockQuantity  Int?
  digitalFileKey String?

  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])

  createdById String
  createdBy   User   @relation("CreatedByAdmin", fields: [createdById], references: [id])

  variants   ProductVariant[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}

model ProductVariant {
  id            String   @id @default(cuid())
  name          String
  price         Decimal?
  stockQuantity Int?

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("product_variants")
}

// ============================================================
// COUPON / VOUCHER
// ============================================================

model Coupon {
  id             String       @id @default(cuid())
  code           String       @unique
  discountType   DiscountType
  discountValue  Decimal
  minOrderAmount Decimal      @default(0)
  maxUses        Int?
  usedCount      Int          @default(0)
  expiresAt      DateTime?
  isActive       Boolean      @default(true)

  appliedOrders Order[]
  orderItems    OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("coupons")
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ============================================================
// ORDER & PAYMENT
// ============================================================

model Order {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id])

  totalAmount    Decimal
  discountAmount Decimal     @default(0)
  finalAmount    Decimal

  status           OrderStatus @default(PENDING)
  xenditInvoiceId  String?
  xenditInvoiceUrl String?
  xenditInvoiceExpiresAt DateTime?
  paymentProof     String?

  deliveredAt   DateTime?
  deliveredById String?
  deliveredBy   User?    @relation("DeliveredBy", fields: [deliveredById], references: [id])
  deliveryNote  String?

  couponId String?
  coupon   Coupon? @relation(fields: [couponId], references: [id])

  items        OrderItem[]
  activityLogs ActivityLog[] @relation("OrderLogs")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  DELIVERED
  CANCELLED
  REFUNDED
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  couponId  String?
  coupon    Coupon? @relation(fields: [couponId], references: [id])

  quantity  Int     @default(1)
  unitPrice Decimal
  subtotal  Decimal

  @@map("order_items")
}

// ============================================================
// ACTIVITY LOG
// ============================================================

model ActivityLog {
  id         String      @id @default(cuid())
  category   LogCategory
  action     String
  entityType String?
  entityId   String?

  actorId String?
  actor   User?   @relation("ActorLogs", fields: [actorId], references: [id])

  details Json?

  createdAt DateTime @default(now())

  orderId String?
  order   Order?  @relation("OrderLogs", fields: [orderId], references: [id])

  @@index([category])
  @@index([action])
  @@index([entityType, entityId])
  @@map("activity_logs")
}

enum LogCategory {
  AUTH
  USER
  PRODUCT
  ORDER
  PAYMENT
  DELIVERY
  COUPON
  SYSTEM
  SECURITY
}
